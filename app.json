{
  "expo": {
    "name": "Sentosa ATK",
    "slug": "sistem-inventaris-sentosa-atk",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sisteminventarissentosaatk",
    "userInterfaceStyle": "automatic",
    "ios": {
      "buildNumber": "9",
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "REQUEST_INSTALL_PACKAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 9,
      "package": "com.anonymous.sisteminventarissentosaatk",
      "googleServicesFile": "./google-services.json"
    },
    "updates": {
      "url": "https://u.expo.dev/d9e98c14-1318-432b-88a3-3889af0bf951",
      "fallbackToCacheTimeout": 0
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d9e98c14-1318-432b-88a3-3889af0bf951"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
